                    <button
                      className="btn btn-danger btn-sm"
                      onClick={() => {
                        dispatch({
                          type: "REMOVE_FROM_CART",
                          id: item.product.id,
                        });
                        dispatch({
                          type: "ADD_TOAST",
                          toast: {
                            type: "info",
                            title: "ÄÃ£ xÃ³a khá»i giá» hÃ ng",
                          },
                        });
                      }}
                    >
                      ðŸ—‘ï¸ XÃ³a
                    </button>
                    <button
                      className="btn btn-ghost btn-sm"
                      onClick={() => {
                        dispatch({
                          type: "TOGGLE_WISHLIST",
                          id: item.product.id,
                        });
                        dispatch({
                          type: "ADD_TOAST",
                          toast: {
                            type: "info",
                            title: "ÄÃ£ lÆ°u vÃ o yÃªu thÃ­ch",
                          },
                        });
                      }}
                    >
                      {state.wishlist.includes(item.product.id) ? "â¤ï¸" : "ðŸ¤"}{" "}
                      YÃªu thÃ­ch
                    </button>
                  </div>
                </div>
                <div className="cart-item-price">
                  {formatPrice(item.product.price * item.qty)}
                </div>
              </div>
            ))}
          </div>
          <div
            style={{
              marginTop: 16,
              display: "flex",
              justifyContent: "space-between",
            }}
          >
            <button className="btn btn-ghost" onClick={() => nav("products")}>
              â† Tiáº¿p tá»¥c mua sáº¯m
            </button>
            <button
              className="btn btn-danger"
              onClick={() => {
                dispatch({ type: "CLEAR_CART" });
                dispatch({
                  type: "ADD_TOAST",
                  toast: { type: "info", title: "ÄÃ£ xÃ³a táº¥t cáº£ sáº£n pháº©m" },
                });
              }}
            >
              ðŸ—‘ï¸ XÃ³a táº¥t cáº£
            </button>
          </div>

          {/* PROMO HINTS */}
          <div
