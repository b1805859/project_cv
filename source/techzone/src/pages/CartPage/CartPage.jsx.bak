                      style={{
                        fontFamily: "var(--font-mono)",
                        color: "var(--accent)",
                      }}
                    >
                      {promo.code}
                    </strong>
                    <span style={{ color: "var(--muted)", marginLeft: 6 }}>
                      {promo.label}
                    </span>
                  </div>
                ))}
            </div>
          </div>
        </div>

        <div className="cart-summary">
          <div className="summary-title">TÃ³m táº¯t Ä‘Æ¡n hÃ ng</div>
          <div className="summary-row">
            <span>
              Táº¡m tÃ­nh ({state.cart.reduce((s, i) => s + i.qty, 0)} sáº£n pháº©m)
            </span>
            <span>{formatPrice(subtotal)}</span>
          </div>
          <div className="summary-row">
            <span>PhÃ­ váº­n chuyá»ƒn</span>
            <span
              style={{ color: shipping === 0 ? "var(--green)" : "inherit" }}
            >
              {shipping === 0 ? "Miá»…n phÃ­ ðŸŽ‰" : formatPrice(shipping)}
            </span>
          </div>

          {/* PROMO CODE INPUT */}
          <div
            style={{
              margin: "14px 0",
              background: "var(--card2)",
              borderRadius: 10,
              padding: 12,
