                          dispatch({
                            type: "UPDATE_CART_QTY",
                            id: item.product.id,
                            qty: item.qty - 1,
                          })
                        }
                      >
                        âˆ’
                      </button>
                      <span
                        style={{
                          fontFamily: "var(--font-head)",
                          fontWeight: 700,
                          minWidth: 24,
                          textAlign: "center",
